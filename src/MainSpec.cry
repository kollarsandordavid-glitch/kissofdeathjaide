MAX_SAMPLES = 1000000

DEFAULT_SAMPLE_LIMIT : [64]
DEFAULT_SAMPLE_LIMIT = 1000000

DEFAULT_GRADIENT_CLIP_NORM : Float32
DEFAULT_GRADIENT_CLIP_NORM = fpFromRational rmNearestTiesToEven (5 % 1)

