MAX_NUM_EPOCHS = 100000

DEFAULT_LEARNING_RATE : Float32
DEFAULT_LEARNING_RATE = fpFromRational rmNearestTiesToEven (1 % 1000)

MIN_LEARNING_RATE : Float32
MIN_LEARNING_RATE = fpFromRational rmNearestTiesToEven (1 % 10000000000)

MAX_LEARNING_RATE : Float32
MAX_LEARNING_RATE = fpFromRational rmNearestTiesToEven (10 % 1)

DEFAULT_TRAINING_SAMPLES : [64]
DEFAULT_TRAINING_SAMPLES = 100

