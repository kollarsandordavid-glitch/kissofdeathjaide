ANCHOR_MODULO = 3

TENSOR_INIT_SCALE : Float32
TENSOR_INIT_SCALE = fpFromRational rmNearestTiesToEven (1 % 10)

PARAM_UPDATE_DELTA : Float32
PARAM_UPDATE_DELTA = fpFromRational rmNearestTiesToEven (1 % 1000)

GRADIENT_SCALE : Float32
GRADIENT_SCALE = fpFromRational rmNearestTiesToEven (1 % 100)

GRADIENT_RANGE_SCALE : Float32
GRADIENT_RANGE_SCALE = fpFromRational rmNearestTiesToEven (10 % 1)

NORM_TOLERANCE : Float32
NORM_TOLERANCE = fpFromRational rmNearestTiesToEven (1 % 10)

CHANGE_THRESHOLD : Float32
CHANGE_THRESHOLD = fpFromRational rmNearestTiesToEven (1 % 1000000)

GRADIENT_THRESHOLD : Float32
GRADIENT_THRESHOLD = fpFromRational rmNearestTiesToEven (1 % 1000000000)

R_SQUARED_EPSILON : Float64
R_SQUARED_EPSILON = fpFromRational rmNearestTiesToEven (1 % 10000000000)

CONFIDENCE_Z_SCORE : Float64
CONFIDENCE_Z_SCORE = fpFromRational rmNearestTiesToEven (196 % 100)

PRNG_SEED_FORWARD : [64]
PRNG_SEED_FORWARD = 54321

PRNG_SEED_VALIDATION : [64]
PRNG_SEED_VALIDATION = 12345

