let min_u64_spec = do {
    a <- llvm_var "a" (llvm_int 64);
    b <- llvm_var "b" (llvm_int 64);
    let result = if a < b then a else b;
    llvm_return result;
};

let max_u64_spec = do {
    a <- llvm_var "a" (llvm_int 64);
    b <- llvm_var "b" (llvm_int 64);
    let result = if a > b then a else b;
    llvm_return result;
};

let clamp_u64_spec = do {
    val <- llvm_var "val" (llvm_int 64);
    lo <- llvm_var "lo" (llvm_int 64);
    hi <- llvm_var "hi" (llvm_int 64);
    let result = if val < lo then lo else if val > hi then hi else val;
    llvm_return result;
};

