    let beta1 = 0.9;
    let beta2 = 0.999;
    let epsilon = 0.00000001;
    t_ptr <- llvm_field sfd_ptr "t";
    t <- llvm_loadw 64 t_ptr;
    let t_new = t + 1;
    llvm_storew 64 t_new t_ptr;
    param_size_ptr <- llvm_field sfd_ptr "param_size";
    param_size <- llvm_loadw 64 param_size_ptr;
    m_ptr <- llvm_field sfd_ptr "m";
    v_ptr <- llvm_field sfd_ptr "v";
    grads_data_ptr <- llvm_field grads_ptr "data";
    params_data_ptr <- llvm_field params_ptr "data";
    llvm_return ();
};

