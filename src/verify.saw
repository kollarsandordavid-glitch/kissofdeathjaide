enable_experimental;

let main_bc = llvm_load_module "main.bc";

let config_init_spec = do {
    config <- llvm_alloc (llvm_struct "Config");
    embedding_dim_ptr <- llvm_field config "embedding_dim";
    llvm_storew 64 DEFAULT_EMBEDDING_DIM embedding_dim_ptr;
    rsf_layers_ptr <- llvm_field config "rsf_layers";
    llvm_storew 64 DEFAULT_RSF_LAYERS rsf_layers_ptr;
    batch_size_ptr <- llvm_field config "batch_size";
    llvm_storew 64 DEFAULT_BATCH_SIZE batch_size_ptr;
    num_epochs_ptr <- llvm_field config "num_epochs";
    llvm_storew 64 DEFAULT_NUM_EPOCHS num_epochs_ptr;
    learning_rate_ptr <- llvm_field config "learning_rate";
    llvm_store_f32 DEFAULT_LEARNING_RATE learning_rate_ptr;
    num_training_samples_ptr <- llvm_field config "num_training_samples";
    llvm_storew 64 DEFAULT_TRAINING_SAMPLES num_training_samples_ptr;
    num_validation_samples_ptr <- llvm_field config "num_validation_samples";
    llvm_storew 64 DEFAULT_VALIDATION_SAMPLES num_validation_samples_ptr;
    sample_limit_ptr <- llvm_field config "sample_limit";
    llvm_storew 64 DEFAULT_SAMPLE_LIMIT sample_limit_ptr;
    gradient_clip_norm_ptr <- llvm_field config "gradient_clip_norm";
    llvm_store_f32 DEFAULT_GRADIENT_CLIP_NORM gradient_clip_norm_ptr;
    sequence_length_ptr <- llvm_field config "sequence_length";
    llvm_storew 64 DEFAULT_SEQUENCE_LENGTH sequence_length_ptr;
    top_k_ptr <- llvm_field config "top_k";
    llvm_storew 64 DEFAULT_TOP_K top_k_ptr;
    llvm_return config;
};

let calculate_total_params_spec = do {
    dim <- llvm_var "dim" (llvm_int 64);
    layers <- llvm_var "layers" (llvm_int 64);
    result <- llvm_var "result" (llvm_int 64);
    llvm_ptr "dim" dim;
    llvm_ptr "layers" layers;
    result_ptr <- llvm_var "result_ptr" (llvm_ptr (llvm_int 64));
    llvm_return result;
};

let validate_config_spec = do {
    config <- llvm_var "config" (llvm_ptr (llvm_struct "Config"));
    embedding_dim_ptr <- llvm_field config "embedding_dim";
    embedding_dim <- llvm_loadw 64 embedding_dim_ptr;
    rsf_layers_ptr <- llvm_field config "rsf_layers";
    rsf_layers <- llvm_loadw 64 rsf_layers_ptr;
    batch_size_ptr <- llvm_field config "batch_size";
    batch_size <- llvm_loadw 64 batch_size_ptr;
    num_epochs_ptr <- llvm_field config "num_epochs";
    num_epochs <- llvm_loadw 64 num_epochs_ptr;
    learning_rate_ptr <- llvm_field config "learning_rate";
    learning_rate <- llvm_load_f32 learning_rate_ptr;
    num_training_samples_ptr <- llvm_field config "num_training_samples";
    num_training_samples <- llvm_loadw 64 num_training_samples_ptr;
    num_validation_samples_ptr <- llvm_field config "num_validation_samples";
    num_validation_samples <- llvm_loadw 64 num_validation_samples_ptr;
    top_k_ptr <- llvm_field config "top_k";
    top_k <- llvm_loadw 64 top_k_ptr;
    gradient_clip_norm_ptr <- llvm_field config "gradient_clip_norm";
    gradient_clip_norm <- llvm_load_f32 gradient_clip_norm_ptr;
    let valid = 
        (embedding_dim >= MIN_EMBEDDING_DIM) && 
        (embedding_dim <= MAX_EMBEDDING_DIM) &&
        (rsf_layers >= MIN_RSF_LAYERS) && 
        (rsf_layers <= MAX_RSF_LAYERS) &&
        (batch_size >= MIN_BATCH_SIZE) && 
        (batch_size <= MAX_BATCH_SIZE) &&
        (num_epochs <= MAX_NUM_EPOCHS) &&
        (num_training_samples >= MIN_SAMPLES) && 
        (num_training_samples <= MAX_SAMPLES) &&
        (num_validation_samples <= MAX_SAMPLES) &&
        (top_k > 0) &&
        (gradient_clip_norm > 0);
    llvm_return valid;
};

let prng_init_spec = do {
    seed <- llvm_var "seed" (llvm_int 64);
    state_ptr <- llvm_alloc (llvm_int 64);
    llvm_storew 64 seed state_ptr;
    llvm_return state_ptr;
};

let prng_next_spec = do {
    state_ptr <- llvm_var "state_ptr" (llvm_ptr (llvm_int 64));
    state <- llvm_loadw 64 state_ptr;
    let mult = 6364136223846793005;
    let incr = 1442695040888963407;
    let new_state = mult * state + incr;
    llvm_storew 64 new_state state_ptr;
    llvm_return new_state;
};

