    k <- llvm_var "k" (llvm_int 64);
    prng_ptr <- llvm_var "prng_ptr" (llvm_ptr (llvm_struct "PRNG"));
    sorted_indices_ptr <- llvm_alloc (llvm_array 16384 (llvm_int 64));
    top_k_indices_ptr <- sorted_indices_ptr;
    top_k_logits_ptr <- llvm_alloc (llvm_array 16384 (llvm_float));
    state_ptr <- llvm_field prng_ptr "state";
    state <- llvm_loadw 64 state_ptr;
    let mult = 6364136223846793005;
    let incr = 1442695040888963407;
    let new_state = mult * state + incr;
    llvm_storew 64 new_state state_ptr;
    result_idx <- llvm_loadw 64 (llvm_ptr_add top_k_indices_ptr 0);
    llvm_return result_idx;
};

